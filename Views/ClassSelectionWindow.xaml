<Window x:Class="SpieleLernApp.Views.ClassSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klassenauswahl"
        Width="1280"
        Height="720"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#132016">
    <Grid x:Name="RootGrid">
        <Rectangle Fill="#52101710" />

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22,16"
                    Background="#D6172219"
                    CornerRadius="24"
                    BorderBrush="#99F6ECC0"
                    BorderThickness="1.5">
                <StackPanel>
                    <TextBlock Text="Klassenauswahl"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FFFDFBEF" />
                    <TextBlock Text="Hier kannst du später direkt in die passende Lernwelt springen."
                               Margin="0,8,0,0"
                               FontSize="18"
                               Foreground="#FFF1EFD9" />
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="1"
                         Margin="0,28,0,0"
                         Rows="2"
                         Columns="2">
                <Button Margin="0,0,16,16"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="ClassButton_Click"
                        Tag="Klasse 1">
                    <Border CornerRadius="26"
                            BorderBrush="#FFF6D873"
                            BorderThickness="3">
                        <Grid>
                            <Image x:Name="Class1Image"
                                   Stretch="UniformToFill" />
                            <Border Background="#44000000"
                                    VerticalAlignment="Bottom"
                                    Height="68">
                                <TextBlock Text="Klasse 1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>
                </Button>

                <Button Margin="16,0,0,16"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="ClassButton_Click"
                        Tag="Klasse 2">
                    <Border CornerRadius="26"
                            BorderBrush="#FFF6D873"
                            BorderThickness="3">
                        <Grid>
                            <Image x:Name="Class2Image"
                                   Stretch="UniformToFill" />
                            <Border Background="#44000000"
                                    VerticalAlignment="Bottom"
                                    Height="68">
                                <TextBlock Text="Klasse 2"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>
                </Button>

                <Button Margin="0,16,16,0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="ClassButton_Click"
                        Tag="Klasse 3">
                    <Border CornerRadius="26"
                            BorderBrush="#FFF6D873"
                            BorderThickness="3">
                        <Grid>
                            <Image x:Name="Class3Image"
                                   Stretch="UniformToFill" />
                            <Border Background="#44000000"
                                    VerticalAlignment="Bottom"
                                    Height="68">
                                <TextBlock Text="Klasse 3"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>
                </Button>

                <Button Margin="16,16,0,0"
                        BorderThickness="0"
                        Background="Transparent"
                        Cursor="Hand"
                        Click="ClassButton_Click"
                        Tag="Klasse 4">
                    <Border CornerRadius="26"
                            BorderBrush="#FFF6D873"
                            BorderThickness="3">
                        <Grid>
                            <Image x:Name="Class4Image"
                                   Stretch="UniformToFill" />
                            <Border Background="#44000000"
                                    VerticalAlignment="Bottom"
                                    Height="68">
                                <TextBlock Text="Klasse 4"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>
                </Button>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>
