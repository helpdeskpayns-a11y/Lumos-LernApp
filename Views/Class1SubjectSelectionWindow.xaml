<Window x:Class="SpieleLernApp.Views.Class1SubjectSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Klasse 1 - Fächerauswahl"
        Width="1280"
        Height="720"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#122018">
    <Grid x:Name="RootGrid">
        <Rectangle Fill="#46122018" />

        <Grid Margin="34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22,18"
                    Background="#D6172219"
                    CornerRadius="24"
                    BorderBrush="#99F6ECC0"
                    BorderThickness="1.5">
                <StackPanel>
                    <TextBlock Text="Klasse 1 - Fächerauswahl"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FFFDFBEF" />
                    <TextBlock x:Name="SubtitleTextBlock"
                               Margin="0,8,0,0"
                               FontSize="18"
                               Foreground="#FFF1EFD9" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,26,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="20"
                        Background="#D6172219"
                        CornerRadius="24"
                        BorderBrush="#99F6ECC0"
                        BorderThickness="1.5">
                    <StackPanel>
                        <Border Height="200"
                                CornerRadius="20"
                                ClipToBounds="True">
                            <Image x:Name="ClassImage"
                                   Stretch="UniformToFill" />
                        </Border>

                        <TextBlock Text="Bereich"
                                   Margin="0,18,0,0"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFFDFBEF" />
                        <TextBlock Text="Hier bereitest du die Fächer für Klasse 1 vor."
                                   Margin="0,8,0,0"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Foreground="#FFF1EFD9" />

                        <Border Margin="0,18,0,0"
                                Padding="16"
                                Background="#E8FFF7DD"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Geplante Fächer"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#FF273219" />
                                <TextBlock Text="Mathematik"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           Foreground="#FF405236" />
                                <TextBlock Text="Deutsch"
                                           Margin="0,4,0,0"
                                           FontSize="16"
                                           Foreground="#FF405236" />
                                <TextBlock Text="Sachkunde"
                                           Margin="0,4,0,0"
                                           FontSize="16"
                                           Foreground="#FF405236" />
                                <TextBlock Text="Musik"
                                           Margin="0,4,0,0"
                                           FontSize="16"
                                           Foreground="#FF405236" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="24,0,0,0"
                        Padding="24"
                        Background="#D6172219"
                        CornerRadius="24"
                        BorderBrush="#99F6ECC0"
                        BorderThickness="1.5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Fächer"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FFFDFBEF" />
                            <TextBlock Text="Lege später Fachbilder in `Bilder\\Faecher\\Klasse1\\` ab. Die Auswahl ist bereits vorbereitet."
                                       Margin="0,10,0,0"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       Foreground="#FFF1EFD9" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Margin="0,24,0,0"
                                     Rows="2"
                                     Columns="2">
                            <Button Margin="0,0,14,14"
                                    Padding="16"
                                    Background="#FFF4EED1"
                                    Foreground="#FF273219"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="SubjectButton_Click"
                                    Tag="Mathematik">
                                <StackPanel>
                                    <Border Height="140"
                                            CornerRadius="18"
                                            Background="#22FFFFFF"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="MathImage"
                                                   Stretch="UniformToFill" />
                                            <TextBlock x:Name="MathPlaceholderText"
                                                       Text="Mathematik"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#AA273219" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Mathematik"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Margin="14,0,0,14"
                                    Padding="16"
                                    Background="#FFF4EED1"
                                    Foreground="#FF273219"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="SubjectButton_Click"
                                    Tag="Deutsch">
                                <StackPanel>
                                    <Border Height="140"
                                            CornerRadius="18"
                                            Background="#22FFFFFF"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="GermanImage"
                                                   Stretch="UniformToFill" />
                                            <TextBlock x:Name="GermanPlaceholderText"
                                                       Text="Deutsch"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#AA273219" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Deutsch"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Margin="0,14,14,0"
                                    Padding="16"
                                    Background="#FFF4EED1"
                                    Foreground="#FF273219"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="SubjectButton_Click"
                                    Tag="Sachkunde">
                                <StackPanel>
                                    <Border Height="140"
                                            CornerRadius="18"
                                            Background="#22FFFFFF"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="SachkundeImage"
                                                   Stretch="UniformToFill" />
                                            <TextBlock x:Name="SachkundePlaceholderText"
                                                       Text="Sachkunde"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#AA273219" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Sachkunde"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Margin="14,14,0,0"
                                    Padding="16"
                                    Background="#FFF4EED1"
                                    Foreground="#FF273219"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="SubjectButton_Click"
                                    Tag="Musik">
                                <StackPanel>
                                    <Border Height="140"
                                            CornerRadius="18"
                                            Background="#22FFFFFF"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image x:Name="MusicImage"
                                                   Stretch="UniformToFill" />
                                            <TextBlock x:Name="MusicPlaceholderText"
                                                       Text="Musik"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       Foreground="#AA273219" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Musik"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,24,0,0">
                            <Button Content="Schließen"
                                    Width="150"
                                    Height="46"
                                    Background="#FFF2EECF"
                                    Foreground="#FF273219"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="CloseButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
