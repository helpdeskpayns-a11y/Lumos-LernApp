<Window x:Class="SpieleLernApp.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lumos - LernApp - Startmenü"
        Width="1280"
        Height="720"
        MinWidth="1080"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#132016"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="HotspotButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SceneActionButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FFECD49A" />
            <Setter Property="Foreground"
                    Value="#FF2F2415" />
            <Setter Property="BorderBrush"
                    Value="#CC8B6230" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Viewbox Stretch="Uniform"
                 StretchDirection="Both">
            <Grid Width="1536"
                  Height="1024">
                <Image x:Name="SceneImage"
                       Stretch="Fill" />

                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="34,28,0,0"
                        Padding="18,14"
                        Background="#C9182419"
                        CornerRadius="22"
                        BorderBrush="#99F6ECC0"
                        BorderThickness="1.5">
                    <StackPanel>
                        <TextBlock Text="Startmenü"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#FFFDFBEF" />
                        <TextBlock x:Name="WelcomeTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="16"
                                   Foreground="#FFF1EFD9" />
                    </StackPanel>
                </Border>

                <Canvas>
                    <Button x:Name="WorldsHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="260"
                            Height="82"
                            Canvas.Left="168"
                            Canvas.Top="315"
                            Click="WorldsHotspot_Click" />

                    <Button x:Name="LearningPortalHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="150"
                            Height="238"
                            Canvas.Left="969"
                            Canvas.Top="315"
                            Click="LearningPortalHotspot_Click" />

                    <Button x:Name="ProfileHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="236"
                            Height="74"
                            Canvas.Left="1220"
                            Canvas.Top="384"
                            Click="ProfileHotspot_Click" />

                    <Button x:Name="RewardsHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="236"
                            Height="94"
                            Canvas.Left="1218"
                            Canvas.Top="472"
                            Click="RewardsHotspot_Click" />

                    <Button x:Name="DiaryHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="226"
                            Height="78"
                            Canvas.Left="1222"
                            Canvas.Top="592"
                            Click="DiaryHotspot_Click" />

                    <Button x:Name="TreasureHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="212"
                            Height="162"
                            Canvas.Left="24"
                            Canvas.Top="708"
                            Click="TreasureHotspot_Click" />

                    <Button x:Name="DailyGoalHotspot"
                            Style="{StaticResource HotspotButtonStyle}"
                            Width="220"
                            Height="278"
                            Canvas.Left="1060"
                            Canvas.Top="706"
                            Click="DailyGoalHotspot_Click" />

                    <Button x:Name="SwitchPlayerSceneButton"
                            Content="Spieler wechseln"
                            Style="{StaticResource SceneActionButtonStyle}"
                            Width="230"
                            Height="62"
                            Canvas.Left="408"
                            Canvas.Top="884"
                            Click="SwitchPlayerButton_Click" />

                    <Button x:Name="ExitSceneButton"
                            Content="Beenden"
                            Style="{StaticResource SceneActionButtonStyle}"
                            Width="190"
                            Height="62"
                            Canvas.Left="880"
                            Canvas.Top="884"
                            Background="#FFE9B2A7"
                            Foreground="#FF3E1F16"
                            BorderBrush="#CC8B4B3A"
                            Click="ExitButton_Click" />
                </Canvas>
            </Grid>
        </Viewbox>

        <Border x:Name="DetailPanelBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,26"
                MinWidth="560"
                MaxWidth="1120"
                MaxHeight="620"
                Padding="22"
                Background="#D6172219"
                CornerRadius="28"
                BorderBrush="#99F6ECC0"
                BorderThickness="1.5"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="PanelTitleTextBlock"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#FFFDFBEF" />
                        <TextBlock x:Name="PanelSubtitleTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   Foreground="#FFF1EFD9" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="34"
                            Height="34"
                            Margin="18,0,0,0"
                            Background="#33FFFFFF"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Content="X"
                            Click="CloseDetailButton_Click" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,18,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel x:Name="ProfilePanel"
                                    Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Width="170"
                                            Height="170"
                                            HorizontalAlignment="Center"
                                            CornerRadius="85"
                                            BorderBrush="#FFF6D873"
                                            BorderThickness="3"
                                            Background="#33FFFFFF">
                                        <Grid ClipToBounds="True">
                                            <Ellipse Fill="#44FFFFFF" />
                                            <Image x:Name="AvatarImage"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <Button Content="Spielerbild wählen"
                                            Width="180"
                                            Height="40"
                                            Margin="0,16,0,0"
                                            HorizontalAlignment="Center"
                                            Background="#FFF6D873"
                                            Foreground="#FF273219"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Click="ChooseAvatarButton_Click" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Margin="22,0,0,0"
                                        Padding="18"
                                        Background="#E8FFF7DD"
                                        CornerRadius="22">
                                    <StackPanel>
                                        <TextBlock Text="Spielername"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#FF273219" />
                                        <TextBlock x:Name="PlayerNameInfoText"
                                                   Margin="0,6,0,16"
                                                   FontSize="26"
                                                   Foreground="#FF273219" />
                                        <TextBlock Text="Alter"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#FF273219" />
                                        <TextBlock x:Name="PlayerAgeInfoText"
                                                   Margin="0,6,0,0"
                                                   FontSize="26"
                                                   Foreground="#FF273219" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="RewardsPanel"
                                    Visibility="Collapsed">
                            <StackPanel>
                                <UniformGrid Columns="2">
                                    <Border Margin="0,0,10,0"
                                            Padding="20"
                                            Background="#FFF7E6A8"
                                            CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Text="Pokale im Lernportal"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="#FF5A4200" />
                                            <TextBlock x:Name="TrophiesCountTextBlock"
                                                       Margin="0,8,0,8"
                                                       FontSize="42"
                                                       FontWeight="Bold"
                                                       Foreground="#FF5A4200" />
                                            <TextBlock x:Name="TrophiesInfoTextBlock"
                                                       FontSize="16"
                                                       TextWrapping="Wrap"
                                                       Foreground="#FF7A5D00" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="10,0,0,0"
                                            Padding="20"
                                            Background="#FFE2F0FF"
                                            CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Text="Sterne in den Welten"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="#FF21405E" />
                                            <TextBlock x:Name="StarsCountTextBlock"
                                                       Margin="0,8,0,8"
                                                       FontSize="42"
                                                       FontWeight="Bold"
                                                       Foreground="#FF21405E" />
                                            <TextBlock x:Name="StarsInfoTextBlock"
                                                       FontSize="16"
                                                       TextWrapping="Wrap"
                                                       Foreground="#FF31587A" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Margin="0,18,0,0"
                                        Padding="20"
                                        Background="#E7FFF7E4"
                                        CornerRadius="24">
                                    <StackPanel>
                                        <TextBlock Text="Fehlende Pokale im Lernportal"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#FF273219" />
                                        <TextBlock x:Name="MissingPortalRewardsSummaryTextBlock"
                                                   Margin="0,8,0,0"
                                                   FontSize="15"
                                                   TextWrapping="Wrap"
                                                   Foreground="#FF3D4D34" />
                                        <ItemsControl x:Name="MissingPortalRewardsItemsControl"
                                                      Margin="0,14,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Padding="14"
                                                            Background="#FFF4EED1"
                                                            CornerRadius="16">
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="15"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="#FF3D4D34" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="DiaryPanel"
                                    Visibility="Collapsed">
                            <ItemsControl x:Name="DiaryItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,14"
                                                Padding="18"
                                                Background="#E7FFF7E4"
                                                CornerRadius="20">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="19"
                                                           FontWeight="Bold"
                                                           Foreground="#FF273219" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,8,0,0"
                                                           FontSize="15"
                                                           TextWrapping="Wrap"
                                                           Foreground="#FF3D4D34" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="DailyGoalPanel"
                                    Visibility="Collapsed">
                            <Border Padding="20"
                                    Background="#E7EFF8E2"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock x:Name="DailyGoalTitleTextBlock"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#FF273219" />
                                    <TextBlock x:Name="DailyGoalDescriptionTextBlock"
                                               Margin="0,10,0,0"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Foreground="#FF3D4D34" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="PortalPanel"
                                    Visibility="Collapsed">
                            <Border Padding="12"
                                    Background="#E7FFF7E4"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Im Lernportal wählst du direkt eine Klasse aus."
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Foreground="#FF273219" />
                                    <UniformGrid Columns="4"
                                                 Margin="0,18,0,0">
                                        <Button x:Name="PortalClass1Button"
                                                Margin="0,0,10,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 1">
                                            <StackPanel>
                                                <Border Height="88"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="PortalClass1Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Klasse 1"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="PortalClass1StatusTextBlock"
                                                           Text="Starten"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PortalClass2Button"
                                                Margin="10,0,10,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 2">
                                            <StackPanel>
                                                <Border Height="88"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="PortalClass2Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Klasse 2"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="PortalClass2StatusTextBlock"
                                                           Text="Starten"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PortalClass3Button"
                                                Margin="10,0,10,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 3">
                                            <StackPanel>
                                                <Border Height="88"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="PortalClass3Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Klasse 3"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="PortalClass3StatusTextBlock"
                                                           Text="Starten"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PortalClass4Button"
                                                Margin="10,0,0,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 4">
                                            <StackPanel>
                                                <Border Height="88"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="PortalClass4Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Klasse 4"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="PortalClass4StatusTextBlock"
                                                           Text="Starten"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="WorldsPanel"
                                    Visibility="Collapsed">
                            <Border Padding="18"
                                    Background="#E7FFF7E4"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Hier erreichst du deine Welten. Auch hier kannst du eine Klasse direkt auswählen."
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               Foreground="#FF273219" />
                                    <UniformGrid Columns="2"
                                                 Margin="0,18,0,0">
                                        <Button x:Name="WorldClass1Button"
                                                Margin="0,0,10,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 1">
                                            <StackPanel>
                                                <Border Height="100"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="WorldClass1Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Welt Klasse 1"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="WorldClass1StatusTextBlock"
                                                           Text="Gesperrt"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="WorldClass2Button"
                                                Margin="10,0,0,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 2">
                                            <StackPanel>
                                                <Border Height="100"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="WorldClass2Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Welt Klasse 2"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="WorldClass2StatusTextBlock"
                                                           Text="Gesperrt"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                    <UniformGrid Columns="2"
                                                 Margin="0,12,0,0">
                                        <Button x:Name="WorldClass3Button"
                                                Margin="0,0,10,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 3">
                                            <StackPanel>
                                                <Border Height="100"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="WorldClass3Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Welt Klasse 3"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="WorldClass3StatusTextBlock"
                                                           Text="Gesperrt"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="WorldClass4Button"
                                                Margin="10,0,0,0"
                                                Padding="10"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="17"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="ClassCardButton_Click"
                                                Tag="Klasse 4">
                                            <StackPanel>
                                                <Border Height="100"
                                                        CornerRadius="16"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Image x:Name="WorldClass4Image"
                                                           Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="Welt Klasse 4"
                                                           Margin="0,8,0,0"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock x:Name="WorldClass4StatusTextBlock"
                                                           Text="Gesperrt"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="13"
                                                           FontWeight="Normal" />
                                            </StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="SettingsPanel"
                                    Visibility="Collapsed">
                            <Border Padding="18"
                                    Background="#E7FFF7E4"
                                    CornerRadius="22">
                                <StackPanel>
                                    <CheckBox x:Name="SoundEnabledCheckBox"
                                              Content="Sound aktiv"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              Foreground="#FF273219"
                                              IsChecked="True"
                                              Checked="SoundEnabledCheckBox_Changed"
                                              Unchecked="SoundEnabledCheckBox_Changed" />
                                    <CheckBox x:Name="FullscreenCheckBox"
                                              Margin="0,14,0,0"
                                              Content="Vollbild aktivieren"
                                              FontSize="18"
                                              FontWeight="Bold"
                                              Foreground="#FF273219"
                                              Checked="FullscreenCheckBox_Changed"
                                              Unchecked="FullscreenCheckBox_Changed" />
                                    <TextBlock x:Name="SettingsStatusTextBlock"
                                               Margin="0,18,0,0"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               Foreground="#FF3D4D34" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="Class1SubjectsPanel"
                                    Visibility="Collapsed">
                            <Border Padding="18"
                                    Background="#E7FFF7E4"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Klasse 1"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#FF273219" />
                                    <TextBlock Text="Wähle ein Fach. Alles bleibt dabei im selben Fenster."
                                               Margin="0,8,0,0"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               Foreground="#FF3D4D34" />
                                    <UniformGrid Rows="2"
                                                 Columns="2"
                                                 Margin="0,18,0,0">
                                        <Button Margin="0,0,10,10"
                                                Padding="14"
                                                Background="#FFF4EED1"
                                                Foreground="#FF273219"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="Class1SubjectButton_Click"
                                                Tag="Mathematik">
                                            <StackPanel>
                                                <Border Height="130"
                                                        CornerRadius="18"
                                                        Background="#22FFFFFF"
                                                        ClipToBounds="True">
                                                    <Grid>
